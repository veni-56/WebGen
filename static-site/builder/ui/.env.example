# ── WebGen Builder — Environment Configuration ────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-key

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
FLASK_DEBUG=0

# ── Workers ───────────────────────────────────────────────────────────────────
# Number of job queue workers (in worker container)
WORKER_COUNT=2

# ── Data paths (overridden by Docker volume mounts) ───────────────────────────
DB_PATH=./projects.db
UPLOADS_DIR=./uploads
PUBLISH_DIR=./published
LOG_DIR=./logs

# ── Upload limits ─────────────────────────────────────────────────────────────
# Max upload size in bytes (default 32 MB)
MAX_CONTENT_LENGTH=33554432

# ── CORS (comma-separated allowed origins, or * for all) ─────────────────────
CORS_ORIGINS=

# ── Nginx ports (docker-compose) ─────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── Gunicorn ──────────────────────────────────────────────────────────────────
# Overrides gunicorn.conf.py defaults
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=120
