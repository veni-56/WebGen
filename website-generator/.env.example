# ═══════════════════════════════════════════════════════════════════════════
# WebGen SaaS — Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your values.
# ═══════════════════════════════════════════════════════════════════════════

# ── Flask ─────────────────────────────────────────────────────────────────────
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-secret

# development | production | testing
FLASK_ENV=development
FLASK_DEBUG=1

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
LOG_LEVEL=INFO

# ── Stripe (optional — leave blank to use mock billing in dev) ────────────────
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Get price IDs from: https://dashboard.stripe.com/products
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BIZ_PRICE_ID=price_...

# ── OpenAI (optional — platform works without it) ─────────────────────────────
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Database (optional — SQLite used by default) ──────────────────────────────
# For PostgreSQL on Render/Railway/Supabase:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── App version ───────────────────────────────────────────────────────────────
APP_VERSION=2.0.0
