<style>
/* ── Scrollbar hide ──────────────────────────────────────────── */
.scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
.scrollbar-hide::-webkit-scrollbar { display: none; }

/* ── Category pills ──────────────────────────────────────────── */
.cat-pill {
  @apply inline-flex items-center px-3.5 py-1.5 rounded-full
         text-[13px] font-medium whitespace-nowrap
         bg-gray-100 text-gray-600
         hover:bg-gray-200 active:scale-95
         transition-all duration-150;
}
.cat-pill--active {
  @apply bg-pink-500 text-white hover:bg-pink-600;
}

/* ── Filter / sort chips ─────────────────────────────────────── */
.chip {
  @apply inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full
         text-[12px] font-semibold whitespace-nowrap
         bg-gray-100 text-gray-600
         hover:bg-gray-200 active:scale-95
         transition-all duration-150;
}
.chip--active {
  @apply bg-pink-50 text-pink-600 ring-1 ring-pink-300;
}
.chip--action {
  @apply bg-white border border-gray-300 text-gray-700
         hover:border-gray-400 hover:bg-gray-50;
}
.chip--remove {
  @apply bg-pink-50 text-pink-600 ring-1 ring-pink-200
         hover:bg-pink-100;
}

/* ── Skeleton loading ────────────────────────────────────────── */
.skeleton-card {
  @apply bg-white rounded-2xl p-3 shadow-[0_1px_4px_rgba(0,0,0,.05)];
}
.skeleton {
  @apply bg-gray-200 rounded animate-pulse;
}

/* ── Bottom sheet animation ──────────────────────────────────── */
.sheet-enter {
  animation: slideUp 0.28s cubic-bezier(0.32, 0.72, 0, 1) forwards;
}
.sheet-leave {
  animation: slideDown 0.2s ease-in forwards;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}
@keyframes slideDown {
  from { transform: translateY(0); }
  to   { transform: translateY(100%); }
}

/* ── Price preset buttons ────────────────────────────────────── */
.price-preset {
  @apply w-full py-2.5 rounded-xl border border-gray-200 text-sm font-medium
