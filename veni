{% block scripts %}
<script>
function productListing() {
  return {
    loading: true,
    sheetOpen: false,
    sidebarMin: '{{ min_price }}',
    sidebarMax: '{{ max_price }}',

    init() {
      setTimeout(() => { this.loading = false; }, 300);
    },

    openSheet() {
      this.sheetOpen = true;
      document.body.style.overflow = 'hidden';
    },

    closeSheet() {
      this.sheetOpen = false;
      document.body.style.overflow = '';
    },

    // Bottom sheet price presets
    setPrice(min, max, $event) {
      const form = this.$el.querySelector('form[method="get"]');
      if (!form) return;
      form.querySelector('[name="min_price"]').value = min;
      form.querySelector('[name="max_price"]').value = max;
      form.querySelectorAll('.price-preset').forEach(btn => btn.classList.remove('price-preset--active'));
      $event.currentTarget.classList.add('price-preset--active');
    },

    // Sidebar price presets — updates hidden inputs then submits
    setSidebarPrice(min, max) {
      this.sidebarMin = min;
      this.sidebarMax = max;
      this.$nextTick(() => {
        document.getElementById('sidebarFilterForm').submit();
      });
    },

    // Drag-to-dismiss (touch + mouse)
    startDrag(e) {
      const startY = e.touches ? e.touches[0].clientY : e.clientY;
      const sheet  = e.currentTarget.closest('[class*="rounded-t-3xl"]');
      let   moved  = 0;

      const onMove = (ev) => {
        const y = ev.touches ? ev.touches[0].clientY : ev.clientY;
        moved = Math.max(0, y - startY);
        sheet.style.transform = translateY(${moved}px);
        sheet.style.transition = 'none';
      };

      const onEnd = () => {
        sheet.style.transition = '';
        sheet.style.transform  = '';
        if (moved > 120) this.closeSheet();
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup',   onEnd);
        document.removeEventListener('touchmove', onMove);
        document.removeEventListener('touchend',  onEnd);
      };

      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup',   onEnd);
      document.addEventListener('touchmove', onMove, { passive: true });
      document.addEventListener('touchend',  onEnd);
    },
  }
}
</script>
