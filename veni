          <span class="product-card-rating-value">{{ '%.1f' % p.avg_rating }}</span>
        </div>
        {% if p.review_count is defined and p.review_count > 0 %}
        <span class="product-card-review-count">({{ p.review_count }})</span>
        {% endif %}
      </div>
      {% endif %}

      {# Free delivery badge #}
      <div class="product-card-delivery">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/>
        </svg>
        <span>Free Delivery</span>
      </div>

      {# Add to cart — Alpine AJAX button #}
      {% if show_cart %}
      <div class="product-card-form"
           x-data="cartBtn('{{ url_for('customer.add_to_cart', pid=p.id) }}')">
        <button @click.prevent="add()"
                :disabled="state === 'loading'"
                :class="{
                  'bg-pink-500 hover:bg-pink-600 shadow-sm hover:shadow': state === 'idle',
                  'bg-gray-200 cursor-not-allowed text-gray-400':          state === 'loading',
                  'bg-emerald-500 hover:bg-emerald-600':                   state === 'done',
                  'bg-red-400 hover:bg-red-500':                           state === 'error'
                }"
                class="product-card-btn">

          <template x-if="state === 'idle'">
            <span class="flex items-center justify-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
              Add to Cart
            </span>
          </template>

          <template x-if="state === 'loading'">
            <span class="flex items-center justify-center gap-1.5">
              <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
              </svg>
              Adding…
            </span>
          </template>

          <template x-if="state === 'done'">
            <span class="flex items-center justify-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
              Added!
            </span>
          </template>

          <template x-if="state === 'error'">
            <span class="flex items-center justify-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
              Failed
            </span>
          </template>

        </button>
      </div>
      {% endif %}

    </div>
  </div>
</div>

<style>
/* ── Product card wrapper ──────────────────────────────────── */
.product-card-wrapper {
  height: 100%;
}

/* ── Card container ────────────────────────────────────────── */
.product-card {
  @apply bg-white rounded-2xl overflow-hidden h-full flex flex-col
         shadow-[0_1px_4px_rgba(0,0,0,.05)]
         hover:shadow-[0_4px_20px_rgba(0,0,0,.09)]
         transition-all duration-200 hover:-translate-y-0.5;
}

/* ── Image wrapper ─────────────────────────────────────────── */
.product-card-image-wrapper {
  @apply relative aspect-square overflow-hidden bg-gray-50;
}

.product-card-image {
  @apply w-full h-full object-cover transition-transform duration-300;
}

.product-card:hover .product-card-image {
  @apply scale-105;
}

/* ── Discount badge ────────────────────────────────────────── */
.product-card-badge {
  @apply absolute top-2 left-2 bg-orange-500 text-white
         text-[10px] font-bold px-1.5 py-0.5 rounded-md leading-none
         shadow-sm z-10;
}

/* ── Wishlist button ───────────────────────────────────────── */
.product-card-wishlist {
  @apply absolute top-2 right-2 w-8 h-8 rounded-full
         bg-white/90 backdrop-blur-sm hover:bg-white
         flex items-center justify-center
         text-gray-400 hover:text-pink-500
         shadow-sm hover:shadow transition-all duration-150
         opacity-0 group-hover:opacity-100 z-10;
}

/* ── Card body ─────────────────────────────────────────────── */
.product-card-body {
  @apply p-3 flex flex-col gap-1.5 flex-1;
}

/* ── Product title ─────────────────────────────────────────── */
.product-card-title {
  @apply text-sm font-medium text-gray-800 leading-snug
         line-clamp-2 min-h-[2.5rem];
}

.product-card-link {
  @apply text-gray-800 hover:text-pink-500 transition-colors no-underline;
}

/* ── Price row ─────────────────────────────────────────────── */
.product-card-price-row {
  @apply flex items-baseline gap-1.5 flex-wrap;
}

.product-card-price {
  @apply text-gray-900 font-bold text-base leading-none;
}

.product-card-price-original {
  @apply text-gray-400 text-xs line-through leading-none;
}

.product-card-discount {
  @apply text-emerald-600 text-[11px] font-semibold leading-none;
}

/* ── Rating ────────────────────────────────────────────────── */
.product-card-rating {
  @apply flex items-center gap-1.5 text-xs;
}

.product-card-stars {
  @apply flex items-center gap-1 bg-emerald-50 text-emerald-700
         px-1.5 py-0.5 rounded font-semibold;
}

.product-card-rating-value {
  @apply leading-none;
}

.product-card-review-count {
  @apply text-gray-400 leading-none;
}

/* ── Free delivery badge ───────────────────────────────────── */
.product-card-delivery {
  @apply flex items-center gap-1 text-[11px] font-medium text-gray-500;
}

/* ── Add to cart form ──────────────────────────────────────── */
.product-card-form {
  @apply mt-auto pt-1;
}

.product-card-btn {
  @apply w-full flex items-center justify-center gap-1.5
         bg-pink-500 hover:bg-pink-600 active:bg-pink-700
         text-white font-semibold text-sm px-4 py-2 rounded-full
         transition-all duration-150 shadow-sm hover:shadow
         focus:outline-none focus:ring-2 focus:ring-pink-300 focus:ring-offset-1;
}

/* ── Responsive adjustments ────────────────────────────────── */
@media (max-width: 640px) {
  .product-card-title {
    @apply text-xs min-h-[2.25rem];
  }
  .product-card-price {
    @apply text-sm;
  }
  .product-card-btn {
    @apply text-xs py-1.5;
  }
  .product-card-body {
    @apply p-2 gap-1;
  }
}
</style>



<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="{% block meta_description %}ShopWave — India's favourite multi-vendor marketplace{% endblock %}"/>
  <title>{% block title %}ShopWave{% endblock %}</title>

  {# ── Tailwind CSS (CDN — swap for compiled build in production) ── #}
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            pink: {
              50:  '#fdf2f8', 100: '#fce7f3', 200: '#fbcfe8',
              300: '#f9a8d4', 400: '#f472b6', 500: '#f43397',
              600: '#db2777', 700: '#be185d', 800: '#9d174d', 900: '#831843',
            },
            gray: {
              950: '#0a0a0a',
            },
          },
          fontFamily: {
            sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
          },
          boxShadow: {
            'xs':         '0 1px 3px rgba(0,0,0,.06)',
            'card':       '0 1px 4px rgba(0,0,0,.05)',
            'card-hover': '0 4px 20px rgba(0,0,0,.09)',
            'nav':        '0 1px 6px rgba(0,0,0,.05)',
            'dropdown':   '0 4px 24px rgba(0,0,0,.10)',
          },
          borderRadius: {
            '2xl': '1rem',
            '3xl': '1.25rem',
          },
        }
      }
    }
  </script>

  {# ── Google Fonts ─────────────────────────────────────── #}
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>

  {# ── Alpine.js for dropdowns / interactivity ─────────── #}
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

  {# ── Shared component styles ──────────────────────────── #}
  <style>
    /* ── Base typography ─────────────────────────────────── */
    body { font-feature-settings: "kern" 1, "liga" 1; }
    h1, h2, h3, h4 { letter-spacing: -0.02em; }

    /* ── Navbar icon button ──────────────────────────────── */
    .nav-icon-btn {
      @apply relative flex items-center justify-center w-9 h-9 rounded-xl
             text-gray-500 hover:text-gray-800 hover:bg-gray-100
             transition-all duration-150 cursor-pointer;
    }

    /* ── Avatar circle — role-coloured ──────────────────── */
    .nav-avatar {
      @apply w-8 h-8 rounded-full font-bold text-sm flex items-center
             justify-center cursor-pointer transition-all duration-150
             ring-2 ring-transparent hover:ring-offset-1 hover:ring-pink-300;
    }
    .nav-avatar--customer { @apply bg-pink-50  text-pink-600; }
    .nav-avatar--seller   { @apply bg-violet-50 text-violet-600; }
    .nav-avatar--admin    { @apply bg-amber-50  text-amber-700; }

    /* ── Notification / cart badge ───────────────────────── */
    .nav-badge {
      @apply absolute -top-0.5 -right-0.5 bg-red-500 text-white
             text-[10px] font-bold min-w-[16px] h-4 px-0.5 rounded-full
             flex items-center justify-center leading-none pointer-events-none;
    }

    /* ── Dropdown wrapper ────────────────────────────────── */
    .nav-avatar-menu { @apply relative; }

    /* ── Dropdown panel ──────────────────────────────────── */
    .nav-dropdown {
      @apply absolute right-0 top-[calc(100%+6px)] w-52 bg-white
             rounded-2xl shadow-[0_4px_24px_rgba(0,0,0,.10)]
             border border-gray-100/80 overflow-hidden z-50 py-1;
    }

    /* ── Dropdown item ───────────────────────────────────── */
    .nav-dropdown-item {
      @apply flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-700
             hover:bg-gray-50 transition-colors duration-100;
    }

    /* ── Flash alerts ────────────────────────────────────── */
    .flash-alert {
      @apply flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium
             border mb-2;
    }
    .flash-success { @apply bg-emerald-50 border-emerald-200 text-emerald-800; }
    .flash-danger  { @apply bg-red-50     border-red-200     text-red-800;     }
    .flash-warning { @apply bg-amber-50   border-amber-200   text-amber-800;   }
    .flash-info    { @apply bg-blue-50    border-blue-200    text-blue-800;    }

    /* ── Product card ────────────────────────────────────── */
    .product-card {
      @apply bg-white rounded-2xl overflow-hidden
             shadow-[0_1px_4px_rgba(0,0,0,.05)]
             hover:shadow-[0_4px_20px_rgba(0,0,0,.09)]
             transition-all duration-200 hover:-translate-y-0.5 cursor-pointer;
    }
    .product-card img {
      @apply transition-transform duration-300;
    }
    .product-card:hover img {
      @apply scale-[1.03];
    }

    /* ── Buttons ─────────────────────────────────────────── */
    .btn-primary {
      @apply inline-flex items-center justify-center gap-2
             bg-pink-500 hover:bg-pink-600 active:bg-pink-700
             text-white font-semibold text-sm px-5 py-2.5 rounded-full
             transition-all duration-150 shadow-sm hover:shadow
             focus:outline-none focus:ring-2 focus:ring-pink-300 focus:ring-offset-1;
    }
    .btn-outline {
      @apply inline-flex items-center justify-center gap-2
             border border-pink-400 text-pink-500
             hover:bg-pink-500 hover:text-white hover:border-pink-500
             font-semibold text-sm px-5 py-2.5 rounded-full
             transition-all duration-150
             focus:outline-none focus:ring-2 focus:ring-pink-300 focus:ring-offset-1;
    }
    .btn-ghost {
      @apply inline-flex items-center justify-center gap-2
             text-gray-600 hover:text-gray-900 hover:bg-gray-100
             font-medium text-sm px-4 py-2 rounded-xl transition-all duration-150;
    }
    .btn-secondary {
      @apply inline-flex items-center justify-center gap-2
             bg-gray-100 hover:bg-gray-200 text-gray-800
             font-semibold text-sm px-5 py-2.5 rounded-full
             transition-all duration-150
             focus:outline-none focus:ring-2 focus:ring-gray-300;
    }

    /* ── Section headings ────────────────────────────────── */
    .section-title {
      @apply text-[17px] font-extrabold text-gray-900 tracking-tight
             flex items-center gap-2 leading-snug;
    }
    .section-subtitle {
      @apply text-sm text-gray-400 font-normal mt-0.5 leading-relaxed;
    }

    /* ── Form inputs ─────────────────────────────────────── */
    .form-input {
      @apply w-full px-4 py-2.5 rounded-xl border border-gray-200
             text-sm text-gray-800 bg-white placeholder-gray-400
             focus:outline-none focus:border-pink-400
             focus:ring-2 focus:ring-pink-100 transition-all duration-150;
    }
    .form-label {
      @apply block text-sm font-semibold text-gray-700 mb-1.5 leading-none;
    }
    .form-hint {
      @apply text-xs text-gray-400 mt-1;
    }

    /* ── Badges ──────────────────────────────────────────── */
    .badge-discount {
      @apply absolute top-2 left-2 bg-orange-500 text-white
             text-[10px] font-bold px-1.5 py-0.5 rounded-md leading-none;
    }
    .badge-new {
      @apply absolute top-2 left-2 bg-emerald-500 text-white
             text-[10px] font-bold px-1.5 py-0.5 rounded-md leading-none;
    }
    .badge-pill {
      @apply inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold;
    }

    /* ── Stat / KPI card ─────────────────────────────────── */
    .stat-card {
      @apply bg-white rounded-2xl p-5
             shadow-[0_1px_4px_rgba(0,0,0,.05)]
             hover:shadow-[0_4px_16px_rgba(0,0,0,.08)]
             transition-shadow duration-200;
    }

    /* ── Footer ──────────────────────────────────────────── */
    .footer-link {
      @apply text-gray-400 hover:text-gray-200 transition-colors duration-150 text-sm;
    }
    .footer-social-btn {
      @apply w-8 h-8 rounded-full bg-white/10 hover:bg-pink-500
             flex items-center justify-center text-gray-400
             hover:text-white transition-all duration-150;
    }

    /* ── Mobile bottom nav ───────────────────────────────── */
    .mobile-nav-item {
      @apply flex-1 flex flex-col items-center justify-center
             gap-0.5 py-2 text-[10px] font-semibold tracking-wide
             transition-colors duration-150 relative;
    }
    .mobile-nav-item svg {
      @apply w-[22px] h-[22px];
    }
    /* Active indicator dot */
    .mobile-nav-item.active-tab { @apply text-pink-500; }
    .mobile-nav-item.active-tab::after {
      content: '';
      @apply absolute bottom-1 w-1 h-1 rounded-full bg-pink-500;
    }

    /* ── Utility ─────────────────────────────────────────── */
    .divider { @apply border-t border-gray-100 my-1; }
    .text-price {
      @apply text-gray-900 font-bold text-base;
    }
    .text-price-original {
      @apply text-gray-400 text-sm line-through;
    }
    .text-discount {
      @apply text-emerald-600 text-xs font-semibold;
    }
  </style>

  {% block head %}{% endblock %}
</head>

<body class="bg-gray-50 font-sans text-gray-900 antialiased">

  {# ── Navbar component ─────────────────────────────────── #}
  {% include 'components/navbar.html' %}

  {# ── Flash messages ───────────────────────────────────── #}
  {% with messages = get_flashed_messages(with_categories=true) %}
    {% if messages %}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-4">
      {% for cat, msg in messages %}
      <div class="flash-alert flash-{{ cat }}" role="alert">
        {# Icon per category #}
        {% if cat == 'success' %}
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        {% elif cat == 'danger' %}
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        {% elif cat == 'warning' %}
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        {% else %}
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        {% endif %}
        <span class="flex-1">{{ msg }}</span>
        <button onclick="this.parentElement.remove()" class="opacity-60 hover:opacity-100 transition-opacity">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  {% endwith %}

  {# ── Main page content ────────────────────────────────── #}
  <main id="main-content">
    {% block content %}{% endblock %}
  </main>

  {# ── Footer component ─────────────────────────────────── #}
  {% include 'components/footer.html' %}

