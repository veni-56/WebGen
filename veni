@customer_bp.route('/cart/add', methods=['POST'])
def add_to_cart():
    data = request.get_json()
    product_id = data.get('product_id')
    qty = data.get('quantity', 1)

    cart = session.get('cart', {})

    cart[str(product_id)] = cart.get(str(product_id), 0) + qty

    session['cart'] = cart

    return jsonify({
