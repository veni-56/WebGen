function cart() {
  return {
    loading: false,
    cartCount: 0,

    async addToCart(productId) {
      this.loading = true;

      try {
        const res = await fetch("/cart/add", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            product_id: productId,
            quantity: 1
          })
        });

        const data = await res.json();

        if (data.success) {
          this.cartCount = data.cart_count;

          // small success effect
          this.showToast("Added to cart ✅");
        } else {
          this.showToast("Failed to add ❌");
        }

      } catch (err) {
        this.showToast("Server error ❌");
      }

      this.loading = false;
    },

    showToast(msg) {
      const t = document.createElement("div");
      t.innerText = msg;
      t.className =
        "fixed bottom-5 left-1/2 -translate-x-1/2 bg-black text-white text-sm px-4 py-2 rounded-full shadow-lg z-50";
      document.body.appendChild(t);

      setTimeout(() => t.remove(), 2000);
    }
  }
}
