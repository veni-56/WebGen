{# ============================================================
   components/product_card.html — Reusable product card
   
   Usage:
   {% include 'components/product_card.html' with context %}
   
   Required variables:
   - product: Product object with fields:
     - id, name, slug, image, price, discount_percent
     - avg_rating (optional), review_count (optional)
   
   Optional variables:
   - show_add_to_cart: boolean (default: true if customer)
   - card_class: additional CSS classes for wrapper
   ============================================================ #}

{% set p = product %}
{% set show_cart = show_add_to_cart if show_add_to_cart is defined else (current_user.is_authenticated and current_user.role == 'customer') %}

<div class="pc-wrap {{ card_class if card_class else '' }}">
  <div class="pc group">

    {# ── Image ──────────────────────────────────────────── #}
    <div class="pc-img-wrap">
      <a href="{{ url_for('customer.product_detail_slug', slug=p.slug) if p.slug else url_for('customer.product_detail', pid=p.id) }}"
         class="block w-full h-full">
        <img src="{{ url_for('static', filename='uploads/' + p.image) }}"
             alt="{{ p.name }}"
             class="pc-img"
             loading="lazy"
             width="400" height="400"
             onerror="this.src='https://placehold.co/400x400/fce4f3/f43397?text=?'"/>
      </a>

      {% if p.discount_percent and p.discount_percent > 0 %}
      <span class="pc-badge" aria-label="{{ p.discount_percent|int }}% discount">
        {{ p.discount_percent|int }}% OFF
      </span>
      {% endif %}

      <button class="pc-wishlist"
              type="button"
              aria-label="Add {{ p.name }} to wishlist">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
      </button>
    </div>

    {# ── Body ───────────────────────────────────────────── #}
    <div class="pc-body">

      <h3 class="pc-title">
        <a href="{{ url_for('customer.product_detail_slug', slug=p.slug) if p.slug else url_for('customer.product_detail', pid=p.id) }}"
           class="pc-title-link">
          {{ p.name }}
        </a>
      </h3>

      <div class="pc-price-row">
        <span class="pc-price">₹{{ '%.0f' % p.price }}</span>
        {% if p.discount_percent and p.discount_percent > 0 %}
          {% set mrp = p.price / (1 - p.discount_percent / 100) %}
          <span class="pc-mrp" aria-label="Original price ₹{{ '%.0f' % mrp }}">₹{{ '%.0f' % mrp }}</span>
          <span class="pc-off">{{ p.discount_percent|int }}% off</span>
        {% endif %}
      </div>

      {% if p.avg_rating is defined and p.avg_rating > 0 %}
      <div class="pc-rating" role="img" aria-label="Rated {{ '%.1f' % p.avg_rating }} out of 5">
        <div class="pc-stars">
          <svg class="w-3 h-3 fill-amber-400" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          <span>{{ '%.1f' % p.avg_rating }}</span>
        </div>
        {% if p.review_count is defined and p.review_count > 0 %}
        <span class="pc-review-count">({{ p.review_count }})</span>
        {% endif %}
      </div>
      {% endif %}

      <div class="pc-delivery" aria-label="Free delivery available">
        <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/>
        </svg>
        <span>Free Delivery</span>
      </div>

      {# Add to cart — Alpine AJAX #}
      {% if show_cart %}
      <div class="pc-cart-wrap"
           x-data="cartBtn('{{ url_for('customer.add_to_cart', pid=p.id) }}')">
        <button @click.prevent="add()"
                :disabled="state === 'loading'"
                :aria-label="state === 'done' ? 'Added to cart' : 'Add to cart'"
                class="pc-btn"
                :class="{
                  'pc-btn--idle':    state === 'idle',
                  'pc-btn--loading': state === 'loading',
                  'pc-btn--done':    state === 'done',
                  'pc-btn--error':   state === 'error'
                }">

          <template x-if="state === 'idle'">
            <span class="pc-btn-inner">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
              Add to Cart
            </span>
          </template>

          <template x-if="state === 'loading'">
            <span class="pc-btn-inner">
              <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
              </svg>
              Adding…
            </span>
          </template>

          <template x-if="state === 'done'">
            <span class="pc-btn-inner">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
              Added!
            </span>
          </template>

          <template x-if="state === 'error'">
            <span class="pc-btn-inner">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
              Retry
            </span>
          </template>

        </button>
      </div>
      {% endif %}

    </div>
  </div>
</div>

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="{% block meta_description %}ShopWave — India's favourite multi-vendor marketplace{% endblock %}"/>
