          <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort=sort, min_price='500', max_price='999') }}"
             class="quick-filter-pill">₹500 - ₹999</a>
          <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort=sort, min_price='1000', max_price='1999') }}"
             class="quick-filter-pill">₹1000 - ₹1999</a>
          <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort=sort, min_price='2000', max_price='') }}"
             class="quick-filter-pill">Above ₹2000</a>
        </div>
      </div>

      {# Action buttons #}
      <div class="flex gap-3 pt-2">
        <a href="{{ url_for('customer.product_listing') }}" 
           class="flex-1 btn-secondary">
          Clear All
        </a>
        <button type="submit" class="flex-1 btn-primary">
          Apply Filters
        </button>
      </div>
    </form>

  </div>
</div>

