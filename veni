                <label class="text-xs text-gray-500 mb-1 block">Max (₹)</label>
                <input type="number" name="max_price" value="{{ max_price }}"
                       placeholder="Any"
                       class="form-input text-center font-semibold"/>
              </div>
            </div>
            {# Quick price presets #}
            <div class="grid grid-cols-2 gap-2">
              <button type="button" @click="setPrice('', '499', $event)"
                      class="price-preset {% if max_price=='499' and not min_price %}price-preset--active{% endif %}">
                Under ₹499
              </button>
              <button type="button" @click="setPrice('500', '999', $event)"
                      class="price-preset {% if min_price=='500' and max_price=='999' %}price-preset--active{% endif %}">
                ₹500 – ₹999
              </button>
              <button type="button" @click="setPrice('1000', '1999', $event)"
                      class="price-preset {% if min_price=='1000' and max_price=='1999' %}price-preset--active{% endif %}">
                ₹1000 – ₹1999
              </button>
              <button type="button" @click="setPrice('2000', '', $event)"
                      class="price-preset {% if min_price=='2000' and not max_price %}price-preset--active{% endif %}">
                Above ₹2000
              </button>
            </div>
          </div>

          {# Rating filter #}
          <div>
            <p class="text-sm font-bold text-gray-900 mb-3">Minimum Rating</p>
            <div class="flex gap-2">
              {% for r in [4, 3, 2] %}
              <label class="rating-chip">
                <input type="radio" name="min_rating" value="{{ r }}" class="sr-only"
                       {% if request.args.get('min_rating', '') == r|string %}checked{% endif %}/>
                <span class="rating-chip-label">{{ r }}★ & up</span>
              </label>
              {% endfor %}
            </div>
          </div>

        </div>

        {# Sticky action bar #}
        <div class="sticky bottom-0 bg-white border-t border-gray-100 px-5 py-4 flex gap-3">
          <a href="{{ url_for('customer.product_listing') }}"
             class="flex-1 flex items-center justify-center py-3 rounded-2xl border border-gray-200 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition-colors">
            Clear All
          </a>
          <button type="submit"
                  class="flex-1 flex items-center justify-center py-3 rounded-2xl bg-pink-500 hover:bg-pink-600 text-white text-sm font-bold transition-colors shadow-sm">
            Apply Filters
          </button>
        </div>
      </form>

    </div>
  </div>

</div>

