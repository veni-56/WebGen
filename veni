{% extends 'base_tailwind.html' %}

{% block title %}
  {%- if q -%}{{ q }} — {% endif -%}
  {%- if selected_cat -%}{{ selected_cat }} — {% endif -%}
  Products — ShopWave
{%- endblock %}

{# ── Compute active filter count for badge ─────────────────── #}
{% set active_filters = [] %}
{% if selected_cat %}{% set _ = active_filters.append(selected_cat) %}{% endif %}
{% if min_price %}{% set _ = active_filters.append('min') %}{% endif %}
{% if max_price %}{% set _ = active_filters.append('max') %}{% endif %}

{% block content %}
<div class="min-h-screen bg-gray-50" x-data="productListing()" x-init="init()">

  {# ════════════════════════════════════════════════════════
     SINGLE STICKY BAR — categories + filter chips + sort
     ════════════════════════════════════════════════════════ #}
  <div class="sticky top-[56px] md:top-[60px] z-30 bg-white border-b border-gray-100 shadow-[0_1px_4px_rgba(0,0,0,.04)]">
    <div class="max-w-7xl mx-auto">

      {# ── Row 1: Category pills ──────────────────────────── #}
      <div class="flex gap-2 overflow-x-auto scrollbar-hide px-4 sm:px-6 pt-3 pb-2.5">
        <a href="{{ url_for('customer.product_listing', q=q, sort=sort, min_price=min_price, max_price=max_price) }}"
           class="cat-pill {% if not selected_cat %}cat-pill--active{% endif %}">
          All
        </a>
        {% for cat in categories %}
        <a href="{{ url_for('customer.product_listing', category=cat, q=q, sort=sort, min_price=min_price, max_price=max_price) }}"
           class="cat-pill {% if selected_cat == cat %}cat-pill--active{% endif %}">
          {{ cat }}
        </a>
        {% endfor %}
      </div>

      {# ── Row 2: Filter chips + Sort ─────────────────────── #}
      <div class="flex items-center gap-2 overflow-x-auto scrollbar-hide px-4 sm:px-6 pb-3">

        {# Filter chip — opens bottom sheet #}
        <button @click="openSheet()"
                class="chip chip--action flex-shrink-0">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
          </svg>
          <span>Filter</span>
          {% if active_filters|length > 0 %}
          <span class="ml-0.5 bg-pink-500 text-white text-[10px] font-bold w-4 h-4 rounded-full flex items-center justify-center leading-none">
            {{ active_filters|length }}
          </span>
          {% endif %}
        </button>

        {# Divider #}
        <div class="w-px h-5 bg-gray-200 flex-shrink-0"></div>

        {# Sort chips #}
        <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort='newest', min_price=min_price, max_price=max_price) }}"
           class="chip {% if sort=='newest' %}chip--active{% endif %} flex-shrink-0">
          ✨ Newest
        </a>
        <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort='discount', min_price=min_price, max_price=max_price) }}"
           class="chip {% if sort=='discount' %}chip--active{% endif %} flex-shrink-0">
          🔥 Discount
        </a>
        <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort='rating', min_price=min_price, max_price=max_price) }}"
           class="chip {% if sort=='rating' %}chip--active{% endif %} flex-shrink-0">
          ⭐ Top Rated
        </a>
        <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort='price_asc', min_price=min_price, max_price=max_price) }}"
           class="chip {% if sort=='price_asc' %}chip--active{% endif %} flex-shrink-0">
          Price ↑
        </a>
        <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort='price_desc', min_price=min_price, max_price=max_price) }}"
           class="chip {% if sort=='price_desc' %}chip--active{% endif %} flex-shrink-0">
          Price ↓
        </a>

        {# Active filter chips (removable) #}
        {% if min_price or max_price %}
        <div class="w-px h-5 bg-gray-200 flex-shrink-0"></div>
        <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort=sort) }}"
           class="chip chip--remove flex-shrink-0">
          ₹{% if min_price %}{{ min_price }}{% else %}0{% endif %} – {% if max_price %}{{ max_price }}{% else %}∞{% endif %}
          <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
