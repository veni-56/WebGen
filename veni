  {# ── Shared component styles ──────────────────────────── #}
  <style>
    /* Navbar icon button */
    .nav-icon-btn {
      @apply relative flex items-center justify-center w-9 h-9 rounded-full text-white/90
             hover:text-white hover:bg-white/15 transition-colors cursor-pointer;
    }
    /* Avatar circle */
    .nav-avatar {
      @apply w-8 h-8 rounded-full bg-white/25 text-white font-bold text-sm
             flex items-center justify-center cursor-pointer hover:bg-white/35 transition-colors;
    }
    /* Dropdown wrapper */
    .nav-avatar-menu { @apply relative; }
    /* Dropdown panel */
    .nav-dropdown {
      @apply absolute right-0 top-full mt-2 w-48 bg-white rounded-xl shadow-xl
             border border-gray-100 overflow-hidden z-50 py-1;
    }
    /* Dropdown item */
    .nav-dropdown-item {
      @apply block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors;
    }
    /* Footer link */
    .footer-link {
      @apply text-gray-400 hover:text-pink-400 transition-colors;
    }
    /* Footer social button */
    .footer-social-btn {
      @apply w-8 h-8 rounded-full bg-gray-800 hover:bg-pink-500 flex items-center
             justify-center text-gray-400 hover:text-white transition-colors;
    }
    /* Flash alert base */
    .flash-alert {
      @apply flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium
             border shadow-sm mb-2;
    }
    .flash-success { @apply bg-green-50 border-green-200 text-green-800; }
    .flash-danger  { @apply bg-red-50   border-red-200   text-red-800;   }
    .flash-warning { @apply bg-amber-50 border-amber-200 text-amber-800; }
    .flash-info    { @apply bg-blue-50  border-blue-200  text-blue-800;  }
    /* Product card */
    .product-card {
      @apply bg-white rounded-2xl overflow-hidden shadow-card hover:shadow-card-hover
             transition-all duration-200 hover:-translate-y-1 cursor-pointer;
    }
    /* Primary button */
    .btn-primary {
      @apply bg-pink-500 hover:bg-pink-600 text-white font-semibold px-5 py-2.5
             rounded-full transition-colors shadow-sm hover:shadow-md;
    }
    /* Outline button */
    .btn-outline {
      @apply border-2 border-pink-500 text-pink-500 hover:bg-pink-500 hover:text-white
             font-semibold px-5 py-2.5 rounded-full transition-colors;
    }
    /* Section heading */
    .section-title {
      @apply text-lg font-extrabold text-gray-900 flex items-center gap-2;
    }
    /* Form input */
    .form-input {
      @apply w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800
             focus:outline-none focus:border-pink-400 focus:ring-2 focus:ring-pink-100
             transition-colors bg-white;
    }
    /* Badge */
    .badge-discount {
      @apply absolute top-2 left-2 bg-orange-500 text-white text-xs font-bold
             px-2 py-0.5 rounded;
    }
    .badge-new {
      @apply absolute top-2 left-2 bg-green-500 text-white text-xs font-bold
             px-2 py-0.5 rounded;
    }
  </style>

  {% block head %}{% endblock %}
</head>

