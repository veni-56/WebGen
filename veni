         active:scale-95 transition-all;
}
.price-preset--active {
  @apply border-pink-400 bg-pink-50 text-pink-600;
}

/* ── Rating chips ────────────────────────────────────────────── */
.rating-chip input:checked + .rating-chip-label {
  @apply bg-amber-50 text-amber-700 ring-1 ring-amber-300;
