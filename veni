  {# ── Global Alpine components ──────────────────────────── #}
  <script>
    // ── Toast helper (global) ─────────────────────────────
    function showToast(msg, type = 'success') {
      const colors = {
        success: 'bg-gray-900 text-white',
        error:   'bg-red-500 text-white',
        info:    'bg-blue-500 text-white',
      };
      const t = document.createElement('div');
      t.className = pointer-events-auto px-4 py-2.5 rounded-full text-sm font-semibold shadow-lg
                     transition-all duration-300 opacity-0 translate-y-2
                     ${colors[type] || colors.success};
      t.textContent = msg;
      document.getElementById('toast-container').appendChild(t);
      // Animate in
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          t.classList.remove('opacity-0', 'translate-y-2');
        });
      });
      // Animate out + remove
      setTimeout(() => {
        t.classList.add('opacity-0', 'translate-y-2');
        setTimeout(() => t.remove(), 300);
      }, 2200);
    }

    // ── cartBtn Alpine component ──────────────────────────
    // Usage: x-data="cartBtn('/cart/add/42')"
    function cartBtn(url) {
      return {
        state: 'idle',   // idle | loading | done | error
        url,

        async add() {
          if (this.state !== 'idle') return;
          this.state = 'loading';

          try {
            const res = await fetch(this.url, {
              method: 'POST',
              headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'Content-Type': 'application/x-www-form-urlencoded',
              },
              body: 'quantity=1',
            });

            if (res.status === 401 || res.redirected) {
              // Not logged in — redirect to login
              window.location.href = "{{ url_for('auth.login') }}";
              return;
            }

            const data = await res.json();

            if (data.ok) {
              this.state = 'done';
              showToast(data.message || 'Added to cart ✓');
              // Broadcast cart count update to navbar badge
              window.dispatchEvent(new CustomEvent('cart-updated', {
                detail: { count: data.cart_count }
              }));
              // Reset button after 2s
              setTimeout(() => { this.state = 'idle'; }, 2000);
            } else {
              this.state = 'error';
              showToast(data.message || 'Could not add to cart', 'error');
              setTimeout(() => { this.state = 'idle'; }, 2000);
            }
          } catch (err) {
            this.state = 'error';
            showToast('Network error. Try again.', 'error');
            setTimeout(() => { this.state = 'idle'; }, 2000);
          }
        },
      }
    }
  </script>

