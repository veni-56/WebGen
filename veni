        {% endfor %}
      </div>
    </div>
  </div>

  {# ── Filter/Sort Bar (sticky) ───────────────────────────── #}
  <div class="bg-white border-b border-gray-100 sticky top-[112px] md:top-[116px] z-20 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-2.5">
      <div class="flex items-center justify-between gap-3">
        
        {# Result count #}
        <div class="flex-1 min-w-0">
          <p class="text-xs text-gray-500 truncate">
            <span class="font-semibold text-gray-900">{{ products|length }}</span> 
            product{{ 's' if products|length != 1 }}
            {% if q %} for "<span class="font-medium">{{ q }}</span>"{% endif %}
          </p>
        </div>

        {# Filter & Sort buttons #}
        <div class="flex items-center gap-2 flex-shrink-0">
          <button @click="$refs.filterSheet.classList.remove('hidden')"
                  class="filter-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
            </svg>
            <span>Filter</span>
          </button>

          <div class="relative" x-data="{ open: false }">
            <button @click="open = !open" class="filter-btn">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"/>
              </svg>
              <span>Sort</span>
            </button>
            <div x-show="open" @click.away="open = false" x-transition
                 class="absolute right-0 top-full mt-2 w-48 bg-white rounded-2xl shadow-dropdown border border-gray-100 overflow-hidden z-50">
              <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort='newest', min_price=min_price, max_price=max_price) }}"
                 class="sort-item {% if sort=='newest' %}active{% endif %}">
                <span>Newest First</span>
                {% if sort=='newest' %}<svg class="w-4 h-4 text-pink-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>{% endif %}
              </a>
              <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort='price_asc', min_price=min_price, max_price=max_price) }}"
                 class="sort-item {% if sort=='price_asc' %}active{% endif %}">
                <span>Price: Low to High</span>
                {% if sort=='price_asc' %}<svg class="w-4 h-4 text-pink-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>{% endif %}
              </a>
              <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort='price_desc', min_price=min_price, max_price=max_price) }}"
                 class="sort-item {% if sort=='price_desc' %}active{% endif %}">
                <span>Price: High to Low</span>
                {% if sort=='price_desc' %}<svg class="w-4 h-4 text-pink-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>{% endif %}
              </a>
              <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort='rating', min_price=min_price, max_price=max_price) }}"
                 class="sort-item {% if sort=='rating' %}active{% endif %}">
                <span>Top Rated</span>
                {% if sort=='rating' %}<svg class="w-4 h-4 text-pink-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>{% endif %}
              </a>
              <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort='discount', min_price=min_price, max_price=max_price) }}"
                 class="sort-item {% if sort=='discount' %}active{% endif %}">
                <span>Discount</span>
                {% if sort=='discount' %}<svg class="w-4 h-4 text-pink-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>{% endif %}
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  {# ── Product Grid ────────────────────────────────────────── #}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 md:py-6">
    {% if products %}
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
        {% for p in products %}
          {% set product = p %}
          {% include 'components/product_card.html' %}
        {% endfor %}
      </div>

      {# Pagination (if needed) #}
      {% if pagination and pagination.pages > 1 %}
      <div class="flex items-center justify-center gap-2 mt-8">
        {% if pagination.has_prev %}
        <a href="{{ url_for('customer.product_listing', page=pagination.prev_num, category=selected_cat, q=q, sort=sort, min_price=min_price, max_price=max_price) }}"
           class="pagination-btn">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
        </a>
        {% endif %}

        {% for page_num in pagination.iter_pages(left_edge=1, right_edge=1, left_current=1, right_current=2) %}
          {% if page_num %}
            <a href="{{ url_for('customer.product_listing', page=page_num, category=selected_cat, q=q, sort=sort, min_price=min_price, max_price=max_price) }}"
               class="pagination-btn {% if page_num == pagination.page %}active{% endif %}">
              {{ page_num }}
            </a>
          {% else %}
            <span class="px-2 text-gray-400">…</span>
          {% endif %}
        {% endfor %}

        {% if pagination.has_next %}
        <a href="{{ url_for('customer.product_listing', page=pagination.next_num, category=selected_cat, q=q, sort=sort, min_price=min_price, max_price=max_price) }}"
           class="pagination-btn">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
        {% endif %}
      </div>
      {% endif %}

    {% else %}
      {# Empty state #}
      <div class="flex flex-col items-center justify-center py-16 px-4">
        <div class="w-32 h-32 mb-6 rounded-full bg-gray-100 flex items-center justify-center">
          <svg class="w-16 h-16 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">No products found</h3>
        <p class="text-sm text-gray-500 text-center max-w-sm mb-6">
          We couldn't find any products matching your search. Try adjusting your filters or search term.
        </p>
        <a href="{{ url_for('customer.product_listing') }}" class="btn-primary">
          Browse All Products
        </a>
      </div>
    {% endif %}
  </div>

</div>

{# ── Filter Bottom Sheet ─────────────────────────────────────── #}
<div class="fixed inset-0 z-50 hidden" x-ref="filterSheet">
  {# Backdrop #}
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm"
       @click="$refs.filterSheet.classList.add('hidden')"></div>
  
  {# Sheet #}
  <div class="absolute bottom-0 left-0 right-0 bg-white rounded-t-3xl shadow-2xl max-h-[85vh] overflow-y-auto">
    
    {# Header #}
    <div class="sticky top-0 bg-white border-b border-gray-100 px-5 py-4 flex items-center justify-between z-10">
      <h3 class="text-base font-bold text-gray-900">Filters</h3>
      <button @click="$refs.filterSheet.classList.add('hidden')"
              class="w-8 h-8 rounded-full hover:bg-gray-100 flex items-center justify-center text-gray-400 hover:text-gray-600 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    {# Filter form #}
    <form method="get" action="{{ url_for('customer.product_listing') }}" class="p-5 space-y-5">
      {% if q %}<input type="hidden" name="q" value="{{ q }}"/>{% endif %}
      {% if selected_cat %}<input type="hidden" name="category" value="{{ selected_cat }}"/>{% endif %}

      {# Price range #}
      <div>
        <label class="form-label">Price Range</label>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <input type="number" name="min_price" 
                   value="{{ min_price }}" 
                   placeholder="Min ₹"
                   class="form-input text-center"/>
          </div>
          <div>
            <input type="number" name="max_price" 
                   value="{{ max_price }}" 
                   placeholder="Max ₹"
                   class="form-input text-center"/>
          </div>
        </div>
      </div>

      {# Quick price filters #}
      <div>
        <label class="form-label mb-2">Quick Filters</label>
        <div class="flex flex-wrap gap-2">
          <a href="{{ url_for('customer.product_listing', category=selected_cat, q=q, sort=sort, min_price='', max_price='499') }}"
