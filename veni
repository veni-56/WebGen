        </span>

      </div>
    </div>
  </div>

  {# ════════════════════════════════════════════════════════
     PRODUCT GRID
     ════════════════════════════════════════════════════════ #}
  <div class="max-w-7xl mx-auto px-3 sm:px-6 py-4 md:py-5">

    {% if products %}

      {# Skeleton loading overlay (shown briefly on page load) #}
      <div x-show="loading" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
        {% for _ in range(8) %}
        <div class="skeleton-card">
          <div class="skeleton aspect-square rounded-xl mb-3"></div>
          <div class="skeleton h-3 rounded w-3/4 mb-2"></div>
          <div class="skeleton h-3 rounded w-1/2 mb-2"></div>
          <div class="skeleton h-3 rounded w-1/3"></div>
        </div>
        {% endfor %}
      </div>

      {# Actual product grid #}
      <div x-show="!loading"
           x-transition:enter="transition-opacity duration-300"
           x-transition:enter-start="opacity-0"
           x-transition:enter-end="opacity-100"
           class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
        {% for p in products %}
          {% set product = p %}
          {% include 'components/product_card.html' %}
        {% endfor %}
      </div>

      {# ── Pagination ──────────────────────────────────────── #}
      {% if pagination and pagination.pages > 1 %}
      <div class="flex items-center justify-center gap-1.5 mt-8 mb-2">
        {% if pagination.has_prev %}
        <a href="{{ url_for('customer.product_listing', page=pagination.prev_num, category=selected_cat, q=q, sort=sort, min_price=min_price, max_price=max_price) }}"
           class="page-btn">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
        </a>
        {% endif %}
        {% for page_num in pagination.iter_pages(left_edge=1, right_edge=1, left_current=1, right_current=2) %}
          {% if page_num %}
            <a href="{{ url_for('customer.product_listing', page=page_num, category=selected_cat, q=q, sort=sort, min_price=min_price, max_price=max_price) }}"
               class="page-btn {% if page_num == pagination.page %}page-btn--active{% endif %}">
              {{ page_num }}
            </a>
          {% else %}
            <span class="px-1 text-gray-400 text-sm">…</span>
          {% endif %}
        {% endfor %}
        {% if pagination.has_next %}
        <a href="{{ url_for('customer.product_listing', page=pagination.next_num, category=selected_cat, q=q, sort=sort, min_price=min_price, max_price=max_price) }}"
           class="page-btn">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
        {% endif %}
      </div>
      {% endif %}

    {% else %}
      {# ── Empty state ─────────────────────────────────────── #}
      <div class="flex flex-col items-center justify-center py-14 px-4 text-center">
        <div class="w-28 h-28 rounded-full bg-pink-50 flex items-center justify-center mb-5">
          <svg class="w-14 h-14 text-pink-300" fill="none" stroke="currentColor" stroke-width="1.25" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-1.5">No products found</h3>
        <p class="text-sm text-gray-500 max-w-xs mb-6 leading-relaxed">
          {% if q %}
            No results for "<strong>{{ q }}</strong>". Try a different keyword.
          {% else %}
            Try adjusting your filters or browse a different category.
          {% endif %}
        </p>

        {# Suggested categories #}
        {% if categories %}
        <div class="mb-6">
          <p class="text-xs text-gray-400 font-medium mb-3 uppercase tracking-wide">Try these categories</p>
          <div class="flex flex-wrap justify-center gap-2">
            {% for cat in categories[:6] %}
            <a href="{{ url_for('customer.product_listing', category=cat) }}"
               class="px-4 py-2 rounded-full bg-white border border-gray-200 text-sm font-medium text-gray-700 hover:border-pink-400 hover:text-pink-500 transition-all shadow-sm">
              {{ cat }}
            </a>
            {% endfor %}
          </div>
        </div>
        {% endif %}

        <div class="flex gap-3">
          <a href="{{ url_for('customer.product_listing') }}" class="btn-primary">
            Browse All
          </a>
          <a href="{{ url_for('customer.deals') }}" class="btn-secondary">
            View Deals
          </a>
        </div>
      </div>
    {% endif %}

  </div>

  {# ════════════════════════════════════════════════════════
     FILTER BOTTOM SHEET
     ════════════════════════════════════════════════════════ #}
  <div x-show="sheetOpen"
       x-transition:enter="transition-opacity duration-200"
       x-transition:enter-start="opacity-0"
       x-transition:enter-end="opacity-100"
       x-transition:leave="transition-opacity duration-150"
       x-transition:leave-start="opacity-100"
       x-transition:leave-end="opacity-0"
       class="fixed inset-0 z-50 bg-black/40 backdrop-blur-[2px]"
       @click.self="closeSheet()"
       style="display:none;">

    {# Sheet panel #}
    <div class="absolute bottom-0 left-0 right-0 bg-white rounded-t-3xl shadow-2xl flex flex-col max-h-[88vh]"
         :class="sheetOpen ? 'sheet-enter' : 'sheet-leave'"
         @click.stop>

      {# Drag handle #}
      <div class="flex justify-center pt-3 pb-1 flex-shrink-0 cursor-grab active:cursor-grabbing"
           @mousedown="startDrag($event)" @touchstart="startDrag($event)">
        <div class="w-10 h-1 rounded-full bg-gray-300"></div>
      </div>

      {# Sheet header #}
      <div class="flex items-center justify-between px-5 py-3 border-b border-gray-100 flex-shrink-0">
        <h3 class="text-base font-bold text-gray-900">Filters</h3>
        <button @click="closeSheet()"
                class="w-8 h-8 rounded-full hover:bg-gray-100 flex items-center justify-center text-gray-400 hover:text-gray-700 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      {# Scrollable filter body #}
      <form method="get" action="{{ url_for('customer.product_listing') }}"
            class="flex-1 overflow-y-auto overscroll-contain">
        {% if q %}<input type="hidden" name="q" value="{{ q }}"/>{% endif %}
        {% if selected_cat %}<input type="hidden" name="category" value="{{ selected_cat }}"/>{% endif %}
        <input type="hidden" name="sort" value="{{ sort }}"/>

        <div class="px-5 py-4 space-y-6">

          {# Price range #}
          <div>
            <p class="text-sm font-bold text-gray-900 mb-3">Price Range</p>
            <div class="grid grid-cols-2 gap-3 mb-4">
              <div>
                <label class="text-xs text-gray-500 mb-1 block">Min (₹)</label>
                <input type="number" name="min_price" value="{{ min_price }}"
